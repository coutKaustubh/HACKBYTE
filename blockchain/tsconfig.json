{
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "node16",
    "target": "es2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "outDir": "dist",
    "types": ["hardhat", "@nomicfoundation/hardhat-ethers"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
